# Before the Title - Environment Variables
# Copy this file to .env.local and fill in your values

# OpenAI API Key (for AI image generation)
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-1

# Supabase (for data storage)
# Get these from your Supabase project settings: https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Required in production: server-side DB writes, storage uploads, and curation.
SUPABASE_SERVICE_ROLE_KEY=

# Required in production: protects /admin and /api/admin.
ADMIN_PASSWORD=
